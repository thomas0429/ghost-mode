# IMPERIUM WEBHOOK SERVER — Environment Variables
# Copy this to .env and fill in your keys
# Then add these same keys in your Railway/Render dashboard

# Google Search (required for searchWeb + lookupLead + news)
# Get free at: serper.dev — $50/month for 50,000 searches
SERPER_API_KEY=your_serper_key_here

# OpenAI (required for askAI with gpt4o)
# Get at: platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# Anthropic Claude (optional — for askAI with claude)
# Get at: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Perplexity (optional — for askAI with perplexity)
# Get at: perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_key_here

# Hunter.io (optional — for email finding in lookupLead)
# Get free tier at: hunter.io
HUNTER_API_KEY=your_hunter_key_here

# Port (Railway sets this automatically)
PORT=3000
